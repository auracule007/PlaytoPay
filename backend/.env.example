# Copy to backend/.env for local dev. Never commit the real .env.

# --- Django -------------------------------------------------------------
DEBUG=1
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string
ALLOWED_HOSTS=*

# --- Database -----------------------------------------------------------
# Postgres is strongly preferred (the locking story relies on real
# row-level locks). For a one-off local run without Docker you can point
# DATABASE_URL at a managed Postgres (Neon, Supabase, Render).
DATABASE_URL=postgres://playto:playto@localhost:5432/playto

# --- Redis / Celery ----------------------------------------------------
# Required by the worker. Leave unset and use eager mode only for tests
# or quick smoke tests where you don't care about background scheduling.
REDIS_URL=redis://localhost:6379/0
# CELERY_TASK_ALWAYS_EAGER=1   # uncomment for sync-only local dev

# --- CORS --------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173
